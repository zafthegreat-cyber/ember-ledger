# Supabase backend import credentials. Use service role only in a private/server environment.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Required because the detected public.product_catalog table is per-user and user_id is NOT nullable.
# Use the UUID from auth.users for the account that should own the imported catalog rows.
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000000

# Optional: Pokémon TCG API key raises rate limits. Leave blank to use unauthenticated calls.
POKEMON_TCG_API_KEY=

# Import controls
TCGCSV_CATEGORY_ID=3
GROUP_LIMIT=0
PRODUCT_BATCH_SIZE=250
PRICE_BATCH_SIZE=500
WRITE_PRICE_HISTORY=false
SCRAPE_TCG_LIST=true
